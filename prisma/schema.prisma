generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id            String            @id @default(uuid())
  email         String            @unique
  emailVerified DateTime?
  fullName      String?
  avatarUrl     String?
  createdAt     DateTime          @default(now())
  conversations Conversation[]
  documents     Document[]
  memberships   WorkspaceMember[]
  auditLogs     AuditLog[]
}

model Workspace {
  id            String            @id @default(uuid())
  name          String
  description   String?
  slug          String            @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  conversations Conversation[]    @relation("WorkspaceConversations")
  documents     Document[]        @relation("WorkspaceDocuments")
  members       WorkspaceMember[] @relation("WorkspaceMembers")
  auditLogs     AuditLog[]        @relation("WorkspaceAuditLogs")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  profileId   String
  role        String    @default("MEMBER")
  createdAt   DateTime  @default(now())
  profile     Profile   @relation(fields: [profileId], references: [id])
  workspace   Workspace @relation("WorkspaceMembers", fields: [workspaceId], references: [id])

  @@unique([workspaceId, profileId])
}

model Document {
  id          String          @id @default(uuid())
  workspaceId String
  profileId   String
  name        String
  content     String?
  fileUrl     String?
  status      String          @default("PROCESSING") // Added for workflow tracking
  createdAt   DateTime        @default(now())
  profile     Profile         @relation(fields: [profileId], references: [id])
  workspace   Workspace       @relation("WorkspaceDocuments", fields: [workspaceId], references: [id])
  chunks      DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1536)")? // Added for semantic search
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id])
}

model Conversation {
  id          String    @id @default(uuid())
  workspaceId String
  profileId   String
  title       String    @default("New Chat")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  profile     Profile   @relation(fields: [profileId], references: [id])
  workspace   Workspace @relation("WorkspaceConversations", fields: [workspaceId], references: [id])
  messages    Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String
  profileId   String
  action      String   // e.g., "QUERY", "UPLOAD", "DELETE"
  details     Json?    // e.g., prompt content, file name
  createdAt   DateTime @default(now())
  profile     Profile  @relation(fields: [profileId], references: [id])
  workspace   Workspace @relation("WorkspaceAuditLogs", fields: [workspaceId], references: [id])
}
